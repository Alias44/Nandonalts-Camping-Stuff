<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<ThingDef>
		<defName>NCS_TentSupport</defName>
		<label>Tent Support</label>
		<thingClass>Building</thingClass>
		<description>Supports the tent.</description>
		<designationCategory Inherit="False"></designationCategory><!--removes recipe from menu-->
		<stuffCategories>
			<li>Metallic</li>
			<li>Woody</li>
		</stuffCategories>
		<graphicData>
			<texPath>CampingStuff/TentSupport</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<shadowData>
				<volume>(0.25, 0.5, 0.25)</volume>
				<offset>(0,0,-0.1)</offset>
			</shadowData>
			<damageData>
				<rect>(0.2,0.2,0.6,0.6)</rect>
			</damageData>
		</graphicData>
		<comps>
		</comps>
		<tickerType>Normal</tickerType>
		<altitudeLayer>Building</altitudeLayer>
		<useHitPoints>false</useHitPoints>
		<statBases>
			<Mass>2</Mass>
		</statBases>
		<fillPercent>0.15</fillPercent>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<resourcesFractionWhenDeconstructed>0</resourcesFractionWhenDeconstructed>
		<pathCost>25</pathCost>
	</ThingDef>

	<ThingDef ParentName="DoorBase" Name="NCS_TentDoor">
		<defName>NCS_TentDoor</defName>
		<label>Tent Door</label>
		<menuHidden>true</menuHidden>
		<description>Divides rooms. Must be manually opened and closed, which slows people down.</description>
		<designationCategory Inherit="False"></designationCategory><!--removes recipe from menu-->
		<graphicData>
			<texPath>CampingStuff/Building/DoorTent_Mover</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<damageData>
				<enabled>false</enabled>
			</damageData>
		</graphicData>
		<uiIconPath>Things/Building/Door/DoorSimple_MenuIcon</uiIconPath>
		<statBases>
			<MaxHitPoints>15</MaxHitPoints>
			<WorkToBuild>85</WorkToBuild>
			<SellPriceFactor>0</SellPriceFactor>
		</statBases>		
		<stuffCategories Inherit="False">
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<building>
			<deconstructible>false</deconstructible>
		</building>
		<damageMultipliers Inherit="False">
			<li>
				<damageDef>Bomb</damageDef>	
				<multiplier>4</multiplier>
			</li>
		</damageMultipliers>
	</ThingDef>
	
	<ThingDef ParentName="Wall" Name="NCS_TentWallBase">
		<defName>NCS_TentWall</defName>
		<label>Tent Wall</label>
		<menuHidden>true</menuHidden>
		<description>A fragile yet practical wall.</description>
		<designationCategory Inherit="False"></designationCategory><!--removes recipe from menu-->
		<graphicData>
			<texPath>CampingStuff/Building/Linked/TentWall_Atlas</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<linkFlags Inherit="False">
				<!--li>Wall</li-->
				<li>Custom1</li>
			</linkFlags>
		</graphicData>
		<statBases>
			<MaxHitPoints>10</MaxHitPoints>
			<WorkToBuild>75</WorkToBuild>
			<SellPriceFactor>0</SellPriceFactor>
		</statBases>
		<stuffCategories Inherit="False">
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<building>
			<deconstructible>false</deconstructible>
		</building>
		<damageMultipliers Inherit="False">
			<li>
				<damageDef>Bomb</damageDef>
				<multiplier>4</multiplier>
			</li>
		</damageMultipliers>
	</ThingDef>
</Defs>